# ============================================================
# HITL AI MULTIMEDIA PIPELINE — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# Gemini (free at aistudio.google.com)
GEMINI_API_KEY=your_gemini_key_here

# Hugging Face (free at huggingface.co/settings/tokens)
HUGGINGFACE_TOKEN=your_hf_token_here

# Modal (free $30/month at modal.com)
MODAL_ENDPOINT_URL=https://your-name--cogvideox-hitl-generate.modal.run

# fal.ai (free credits at fal.ai)
FAL_KEY=your_fal_key_here

# Google Drive (optional, for final video upload)
GDRIVE_CREDENTIALS_JSON=path/to/credentials.json
GDRIVE_FOLDER_ID=your_folder_id_here

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/hitl_pipeline

# Pipeline settings
OUTPUT_DIR=./data/outputs
DEFAULT_MODE=B
SCENE_COUNT=8
SCENE_DURATION_SECONDS=6
MAX_RETRIES_PER_STAGE=3
HUMAN_REVIEW_TIMEOUT_SECONDS=300
ML_REJECTION_THRESHOLD=0.65
